# ── Backend ────────────────────────────────────────────────────────────────────

# Supabase project URL (Settings → API → Project URL)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Supabase service-role key — server-only, bypasses RLS (Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Anthropic API key for Claude (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Claude model to use for scoring
ANTHROPIC_MODEL=claude-sonnet-4-5

# Comma-separated list of allowed CORS origins (no trailing slashes)
CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# ── Frontend (prefix VITE_ so Vite exposes them to the browser) ───────────────

# Base URL of the FastAPI backend (no trailing slash)
VITE_API_URL=http://localhost:8000
